{
  "rules": [
    {
      "expression": "(http.request.uri.path matches \"^/(?!assets|api)\" and not http.request.uri.path contains \".\")",
      "description": "Add no-cache headers to HTML pages",
      "action": "rewrite",
      "action_parameters": {
        "headers": {
          "Cache-Control": {
            "operation": "set",
            "value": "no-store, no-cache, must-revalidate"
          },
          "Surrogate-Control": {
            "operation": "set", 
            "value": "no-store"
          }
        }
      },
      "enabled": true
    }
  ]
}