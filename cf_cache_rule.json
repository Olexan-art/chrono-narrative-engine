{
  "name": "Bypass HTML Cache",
  "description": "Bypass cache for all HTML pages to ensure users get fresh SPA",
  "expression": "(http.response.content_type.type eq \"text/html\")",
  "action": "set_cache_settings",
  "action_parameters": {
    "cache": false,
    "edge_ttl": {
      "mode": "bypass"
    },
    "browser_ttl": {
      "mode": "bypass"
    }
  },
  "enabled": true
}