{
    "name": "bravennow-proxy",
    "main": "src/cloudflare-worker.js",
    "workers_dev": false,
    "preview_urls": false,
    "compatibility_date": "2026-02-15",
    "routes": [
        {
            "pattern": "bravennow.com/*",
            "zone_name": "bravennow.com"
        },
        {
            "pattern": "www.bravennow.com/*",
            "zone_name": "bravennow.com"
        }
    ]
}